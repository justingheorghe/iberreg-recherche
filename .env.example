NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# Externe offizielle Quellenabfragen aktivieren.
# Die App behandelt Fehler tolerant und gibt niemals Fake-Ergebnisse als Treffer aus.
EXTERNAL_LOOKUPS_ENABLED=true
CATASTRO_TIMEOUT_MS=4500
CATASTRO_PUBLIC_BASE_URL=https://ovc.catastro.meh.es/ovcservweb/ovcswlocalizacionrc/ovccallejero.asmx

# Optional fuer produktive Persistenz. Lokal nutzt die App ohne Abhaengigkeiten data/recherchen.jsonl.
DATABASE_URL=postgres://app:app@postgres:5432/immobilien_recherche
DATA_FILE=./data/recherchen.jsonl

# Datenschutz: Aufbewahrung abgeschlossener Recherchen in Tagen.
RETENTION_DAYS=30
